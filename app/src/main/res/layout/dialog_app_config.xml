<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?attr/colorSurface">

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Per-App Time Limit"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/dialog_app_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Instagram"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="16dp"/>

    <!-- Premium Lock Notice — set to VISIBLE by the adapter when per-app limits are locked -->
    <LinearLayout
        android:id="@+id/premium_lock_notice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="14dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔒 Premium Feature"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set a different time limit for each app individually. Available in a future premium update."
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"/>

    </LinearLayout>

    <!-- Use Default Checkbox -->
    <CheckBox
        android:id="@+id/use_default_checkbox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Use global default"
        android:textColor="?attr/colorOnSurface"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

    <!-- Custom Limit Section -->
    <LinearLayout
        android:id="@+id/custom_limit_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Limit Value -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Limit Value"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/limit_value_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="20 minutes"
            android:textSize="14sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="8dp"/>

        <SeekBar
            android:id="@+id/limit_value_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="55"
            android:progress="15"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/cancel_button"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/save_button"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Save"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</LinearLayout>
